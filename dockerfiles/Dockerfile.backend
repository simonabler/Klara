# --- Build stage -----------------------------------------------------------
FROM node:24-alpine AS build

WORKDIR /build/klara

# Install dependencies first (leverages Docker layer cache)
COPY   ./package*.json ./
RUN npm ci

# Copy workspace and build the NestJS server
COPY ./ ./
RUN rm -R ./apps/klara-e2e

# 1. datasource.ts + Migrations kompilieren (CommonJS) → dist/typeorm/
#    Muss VOR dem NX-Build laufen, damit Webpack die JS-Dateien als Assets kopieren kann.
RUN npx tsc -p apps/server/tsconfig.typeorm.json --noEmit false

# 2. NestJS App bauen (Webpack Bundle → dist/apps/server/main.js)
#    Webpack kopiert dabei dist/typeorm/.../migrations/*.js → dist/apps/server/migrations/
RUN npx nx build server

# --- Runtime stage ---------------------------------------------------------
FROM node:24-alpine AS runtime

ENV NODE_ENV=production

RUN apk update && apk upgrade
RUN apk add --no-cache python3 make g++ sqlite-dev py3-setuptools



# ENV npm_config_build_from_source=true
# RUN npm rebuild sqlite3 -g --build-from-sourcepy3-setuptools

WORKDIR /app
RUN chown node:node -R .

USER node

# Copy built server and its production deps
COPY --from=build --chown=node:node /build/klara/dist/apps/server ./
RUN if [ -f package.json ]; then npm ci --omit=dev --ignore-scripts; fi

RUN npm rebuild sqlite3 --build-from-source
RUN npm install pg sharp
COPY --chown=node:node ./apps/server/entrypoint.backend.sh .

EXPOSE 3000
CMD ["sh", "entrypoint.backend.sh"]