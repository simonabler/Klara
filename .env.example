# Datenbank (via Docker-Netzwerk)
TYPEORM_HOST=db
TYPEORM_PORT=5432
TYPEORM_DATABASE=klara
TYPEORM_USERNAME=user
TYPEORM_PASSWORD=CHANGEME
# TYPEORM_SYNC: Nur in Entwicklung auf true setzen!
# In Produktion IMMER false oder weglassen – sonst droht Datenverlust beim Neustart.
TYPEORM_SYNC=false

# App
NODE_ENV=production
PORT=3000

# Auth (wird in Issue 2 benötigt)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
FRONTEND_URL=http://localhost:4200
